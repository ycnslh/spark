# Port d'écoute (utilisé via network_mode: host)
PORT=8085

# Niveau de log: debug | info | warn | error
LOG_LEVEL=info

# Authentification Basic (laisser vide pour désactiver)
AUTH_USER=admin
AUTH_PASS=changeme

# Limite de réveils par minute par IP
WAKE_RATE_LIMIT=10

# Limite d'échecs d'auth par minute par IP (anti brute-force)
AUTH_RATE_LIMIT=5

# Confiance dans X-Forwarded-For (0=jamais, 1=un proxy, 'loopback', etc.)
# À activer uniquement si l'app tourne derrière un reverse proxy
TRUST_PROXY=0

# Chemin de la base SQLite (utilisé en dev seulement, en docker c'est /app/data/spark.db)
# DB_PATH=./data/spark.db
